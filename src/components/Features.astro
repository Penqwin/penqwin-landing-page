---
import FeatureCard from "./FeatureCard.astro";
import ArrowRight from "../assets/svg/arrow-right.astro";
import AllInclusive from "../assets/svg/allInclusive.astro";
import Loop from "../assets/svg/loop.astro";
import Source from "../assets/svg/source.astro";
---

<section
  id="features"
  class="w-full py-16 md:py-32 bg-bg-main relative overflow-hidden"
>
  <div class="max-w-6xl mx-auto px-6 relative z-10">
    <div class="text-center mb-24">
      <h2
        class="font-serif text-4xl md:text-6xl text-text-primary tracking-tight mb-6"
      >
        Everything you need to <span class="text-primary italic">scale</span>
      </h2>
      <p class="text-text-secondary text-lg max-w-2xl mx-auto">
        Powering the next generation of technical teams with tools that feel
        like magic.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <FeatureCard
        title="Understand your codebase from day one"
        description="Connect your repository and Penqwin builds a structured knowledge layer across your architecture, APIs, modules, workflows, and technical systems."
      >
        <Source slot="icon" class="w-7 h-7" />
      </FeatureCard>

      <FeatureCard
        title="Documentation that evolves with your repository"
        description="Penqwin continuously tracks pull requests and code changes to keep documentation aligned with the actual state of your system."
      >
        <Loop slot="icon" class="w-7 h-7 rotate-90" />
      </FeatureCard>

      <FeatureCard
        title="Zero-Maintenance Docs"
        description="Documentation that evolves with code changes. Bridge the gap between your code and your team with docs that are always up-to-date."
      >
        <AllInclusive slot="icon" class="w-7 h-7" />
      </FeatureCard>
    </div>
    <div class="flex justify-center w-full mt-12">
      <a
        href="/features"
        class="inline-flex group items-center justify-center gap-3 px-8 py-4 bg-white/5 border border-white/10 rounded-full text-white font-medium hover:bg-white/10 transition-all active:scale-[0.98]"
        aria-label="Explore all features"
      >
        <span>Explore all features</span>
        <ArrowRight
          class="w-5 h-5 group-hover:translate-x-1"
          aria-hidden="true"
        />
      </a>
    </div>

    <!-- Decorative Accents -->
    <div
      class="absolute top-0 right-0 w-[600px] h-[600px] bg-primary/5 blur-[120px] rounded-full -translate-y-1/2 translate-x-1/2 opacity-20 pointer-events-none"
    >
    </div>
    <div
      class="absolute bottom-0 left-0 w-[600px] h-[600px] bg-accent/5 blur-[120px] rounded-full translate-y-1/2 -translate-x-1/2 opacity-20 pointer-events-none"
    >
    </div>
  </div>

  <style>
    @reference "../styles/global.css";

    .feature-card {
      transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .feature-card:hover {
      transform: translateY(-8px);
    }
  </style>
</section>
