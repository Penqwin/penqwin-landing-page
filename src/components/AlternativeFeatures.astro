<!-- Solution Section -->
<section
  class="space-y-8 relative before:absolute before:-inset-8 before:bg-white/[0.01] before:rounded-3xl before:-z-10 before:border before:border-white/[0.02]"
>
  <h2 class="font-serif text-3xl md:text-4xl font-medium tracking-tight">
    Documentation, directly from your code.
  </h2>
  <p
    class="text-text-secondary font-regular text-lg md:text-xl font-light mb-8"
  >
    No more writing docs from scratch.
  </p>
  <div class="grid gap-6 text-lg sm:text-xl">
    <div class="flex items-baseline gap-4">
      <span class="font-mono text-sm text-text-secondary/50">01</span>
      <span class="text-text-primary"
        >Connect your GitHub repo <em class="text-text-secondary"
          >(public & private)</em
        ></span
      >
    </div>
    <div class="flex items-baseline gap-4">
      <span class="font-mono text-sm text-text-secondary/50">02</span>
      <span class="text-text-primary"
        >Bootstrap technical documentation in seconds</span
      >
    </div>
    <div class="flex items-baseline gap-4">
      <span class="font-mono text-sm text-text-secondary/50">03</span>
      <span class="text-text-primary"
        >Penqwin keeps documentation in sync as code evolves</span
      >
    </div>
    <div class="flex items-baseline gap-4">
      <span class="font-mono text-sm text-text-secondary/50">04</span>
      <span class="text-text-primary">Review, edit, and store it</span>
    </div>
    <div class="flex items-baseline gap-4">
      <span class="font-mono text-sm text-text-secondary/50">05</span>
      <span class="text-text-primary">Engineering knowledge base for teams</span
      >
    </div>
  </div>
</section>

