---
import Tick from "../assets/svg/tick.astro";
---

<!-- Who Penqwin is for & What you get -->
<section class="space-y-8">
  <h2 class="font-serif text-3xl font-medium tracking-tight">
    Who Penqwin is for
  </h2>
  <ul class="flex flex-col gap-6 text-lg text-text-secondary font-light">
    <li class="flex items-start gap-4 group">
      <Tick
        class="w-6 h-6 text-text-primary flex-shrink-0 mt-0.5 group-hover:scale-110 transition-transform"
        aria-hidden="true"
      />
      <span class="text-text-primary">Engineering teams shipping fast</span>
    </li>
    <li class="flex items-start gap-4 group">
      <Tick
        class="w-6 h-6 text-text-primary flex-shrink-0 mt-0.5 group-hover:scale-110 transition-transform"
        aria-hidden="true"
      />
      <span class="text-text-primary"
        >Early-stage startups without time for heavy docs</span
      >
    </li>
    <li class="flex items-start gap-4 group">
      <Tick
        class="w-6 h-6 text-text-primary flex-shrink-0 mt-0.5 group-hover:scale-110 transition-transform"
        aria-hidden="true"
      />
      <span class="text-text-primary"
        >Product teams practicing build-in-public</span
      >
    </li>
    <li class="flex items-start gap-4 group">
      <Tick
        class="w-6 h-6 text-text-primary flex-shrink-0 mt-0.5 group-hover:scale-110 transition-transform"
        aria-hidden="true"
      />
      <span class="text-text-primary"
        >Developers tired of maintaining static documentation</span
      >
    </li>
  </ul>
</section>

<section class="space-y-8">
  <h2 class="font-serif text-3xl font-medium tracking-tight">What you get</h2>
  <ul class="flex flex-col gap-6 text-lg text-text-secondary font-light">
    <li class="flex items-start gap-4 group">
