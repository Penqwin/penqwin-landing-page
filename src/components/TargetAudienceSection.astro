        class="w-6 h-6 text-text-primary flex-shrink-0 mt-0.5 group-hover:scale-110 transition-transform"
        aria-hidden="true"
      />
      <span class="text-text-primary"
        >Faster documentation without extra effort</span
      >
    </li>
    <li class="flex items-start gap-4 group">
      <Tick
        class="w-6 h-6 text-text-primary flex-shrink-0 mt-0.5 group-hover:scale-110 transition-transform"
        aria-hidden="true"
      />
      <span class="text-text-primary"
        >Clear team knowledge without meetings</span
      >
    </li>
    <li class="flex items-start gap-4 group">
      <Tick
        class="w-6 h-6 text-text-primary flex-shrink-0 mt-0.5 group-hover:scale-110 transition-transform"
        aria-hidden="true"
      />
      <span class="text-text-primary"
        >Better onboarding without rewriting docs</span
      >
    </li>
    <li class="flex items-start gap-4 group">
      <Tick
        class="w-6 h-6 text-text-primary flex-shrink-0 mt-0.5 group-hover:scale-110 transition-transform"
        aria-hidden="true"
      />
      <span class="text-text-primary">Compounding knowledge over time</span>
    </li>
  </ul>
</section>
