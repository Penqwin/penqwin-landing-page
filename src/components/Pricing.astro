---
import TickIcon from "../assets/svg/tick.astro";
---

<section
  id="pricing"
  class="w-full py-16 md:py-32 bg-bg-main relative overflow-hidden"
>
  <div class="max-w-6xl mx-auto px-6 relative z-10">
    <div class="text-center mb-16">
      <h2
        class="font-serif text-4xl md:text-6xl text-text-primary tracking-tight mb-6"
      >
        Simple, <span class="text-primary italic">transparent</span> pricing
      </h2>
      <p class="text-text-secondary text-lg max-w-2xl mx-auto">
        Start building better documentation today.
      </p>
    </div>

    <div
      class="grid grid-cols-1 md:grid-cols-2 max-w-4xl mx-auto relative bg-white/[0.02] backdrop-blur-xl border border-white/5 rounded-[2.5rem] transition-all duration-500 hover:bg-white/[0.04] hover:border-primary/20 hover:shadow-[0_40px_80px_-20px_rgba(0,0,0,0.4)] overflow-hidden group"
    >
      <!-- Hover Gradient overlay -->
      <div
        class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"
      >
      </div>
      <!-- Free Card -->
      <div class="relative z-10 w-full p-8 md:p-10 flex flex-col">
        <div
          class="flex flex-col items-start flex-1 pb-8 md:pb-0 md:pr-8 border-b md:border-r md:border-b-0 border-white/10"
        >
          <div
            class="select-none text-text-primary mb-2 text-sm md:text-base font-bold tracking-widest uppercase"
          >
            Free Plan
          </div>

          <div class="flex items-baseline gap-1 mb-8">
            <span
              class="text-4xl md:text-6xl font-serif font-bold text-text-primary tracking-tighter"
              >$0</span
            >
          </div>

          <div class="w-full space-y-3 flex-1">
            {
              [
                "6 Smart Document Generation",
                "12 Documents",
                "Multiple Workspaces",
              ].map((feature) => (
                <div class="flex items-center gap-4 text-text-secondary">
                  <TickIcon class="w-5 h-5 text-primary flex-shrink-0" />
                  <span class="text-sm md:text-base">{feature}</span>
                </div>
              ))
            }
          </div>
        </div>
      </div>

      <!-- Pro Card -->
      <div class="relative z-10 w-full p-8 md:p-10 flex flex-col">
        <div class="flex flex-col items-start flex-1">
          <div
            class="select-none text-text-primary mb-2 text-sm md:text-base font-bold tracking-widest uppercase"
          >
            Pro Plan
          </div>
          <div
            class="absolute select-none top-6 right-6 inline-flex items-center justify-center gap-2 px-1 md:px-2 py-0.5 md:py-1 rounded-full bg-primary/20 border border-primary/50 text-primary text-[8px] md:text-xs font-medium tracking-widest uppercase"
          >
            Early Bird Pricing
          </div>

          <div class="flex items-baseline gap-1 mb-8">
            <span
              class="text-4xl md:text-6xl font-serif font-bold text-text-primary tracking-tighter"
              >$19</span
            >
            <span class="text-text-secondary font-medium">/mo</span>
          </div>

          <div class="w-full space-y-3 flex-1">
            {
              [
                "7 days free trial",
                "Unlimited Smart Document Generation",
                "Unlimited Documents",
                "Team Collaboration",
              ].map((feature, i) => (
                <div class="flex items-center gap-4 text-text-secondary">
                  <TickIcon class="w-5 h-5 text-primary flex-shrink-0" />
                  <span class="text-sm md:text-base">{feature}</span>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
    <!-- CTA -->
    <div class="w-full mt-12">
      <a
        href="https://app.penqwin.com"
        class="w-fit mx-auto select-none group/anchor py-4 px-8 flex items-center justify-center gap-3 bg-white/5 hover:bg-white/10 border border-white/10 text-text-primary rounded-full font-bold transition-all duration-300 active:scale-[0.98] shadow-xl"
      >
        Claim Your Spot
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-5 h-5 transform group-hover/anchor:translate-x-1 transition-transform duration-300"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
        </svg>
      </a>

      <p
        class="mt-6 w-full text-text-secondary text-xs text-center leading-relaxed"
      >
        Get started with the free features right away.
      </p>
    </div>
  </div>

  <!-- Background Orbs -->
  <div
    class="absolute top-1/2 left-0 w-[800px] h-[800px] bg-primary/5 blur-[150px] rounded-full -translate-x-1/2 -translate-y-1/2 opacity-20 pointer-events-none"
  >
  </div>
</section>

<style>
  @reference "../styles/global.css";

  .pricing-card {
    transition: all 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }
</style>
