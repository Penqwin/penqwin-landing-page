---
import TickIcon from "../assets/svg/tick.astro";
import ArrowRight from "../assets/svg/arrow-right.astro";
---

<section id="pricing" class="w-full py-20 md:py-32 bg-bg-main relative overflow-hidden">
  <div class="max-w-5xl mx-auto px-6 relative z-10">

    <!-- Header -->
    <div class="mb-16 md:mb-20">
      <h2 class="font-serif text-4xl md:text-5xl text-text-primary tracking-tight mb-6">
        Simple, <span class="text-primary italic">transparent</span> pricing.
      </h2>
      <p class="text-text-secondary text-lg">
        Start building better documentation today. No credit card required.
      </p>
    </div>

    <!-- Plans -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl">

      <!-- Free Plan -->
      <div class="p-8 md:p-10 bg-white/[0.02] border border-white/5 rounded-[2rem] flex flex-col">
        <div class="mb-8">
          <p class="text-xs font-mono tracking-widest uppercase text-text-secondary mb-4">Free Plan</p>
          <div class="flex items-baseline gap-1">
            <span class="font-serif text-5xl md:text-6xl text-text-primary tracking-tight">$0</span>
          </div>
        </div>

        <div class="space-y-4 flex-1">
          {[
            "Codebase to Documentation",
            "Limited Smart Document Sync",
            "Limited Documents",
            "Multiple Workspaces",
          ].map((feature) => (
            <div class="flex items-center gap-3 text-text-secondary">
              <TickIcon class="w-4 h-4 text-primary flex-shrink-0" />
              <span class="text-base">{feature}</span>
            </div>
          ))}
        </div>

        <div class="mt-10">
          <a
            href="https://app.penqwin.com"
            class="block text-center py-3 px-6 border border-white/10 rounded-full text-text-secondary text-base font-medium hover:border-white/20 hover:text-text-primary transition-colors duration-200"
          >
            Get started free
          </a>
        </div>
      </div>

      <!-- Pro Plan -->
      <div class="relative p-8 md:p-10 bg-primary/5 border border-primary/15 rounded-[2rem] flex flex-col">
        <!-- Badge -->
        <div class="absolute top-6 right-6 inline-flex items-center px-2.5 py-1 rounded-full bg-primary/10 border border-primary/20 text-primary text-xs font-mono tracking-widest uppercase">
          Early Bird
        </div>

        <div class="mb-8">
          <p class="text-xs font-mono tracking-widest uppercase text-primary/70 mb-4">Pro Plan</p>
          <div class="flex items-baseline gap-1.5">
            <span class="font-serif text-5xl md:text-6xl text-text-primary tracking-tight">$19</span>
            <span class="text-text-secondary text-base">/mo</span>
          </div>
        </div>

        <div class="space-y-4 flex-1">
          {[
            "7 days free trial",
            "Codebase to Documentation",
            "Unlimited Smart Document Sync",
            "Unlimited Documents",
            "Team Collaboration",
          ].map((feature) => (
            <div class="flex items-center gap-3 text-text-secondary">
              <TickIcon class="w-4 h-4 text-primary flex-shrink-0" />
              <span class="text-base">{feature}</span>
            </div>
          ))}
        </div>

        <div class="mt-10">
          <a
            href="https://app.penqwin.com"
            class="group flex items-center justify-center gap-2 py-3 px-6 bg-text-primary text-bg-main rounded-full text-base font-bold active:scale-[0.98] transition-transform duration-150"
          >
            <span>Claim Your Spot</span>
            <ArrowRight class="w-4 h-4 group-hover:translate-x-0.5 transition-transform duration-200" />
          </a>
        </div>
      </div>

    </div>

    <p class="mt-8 text-text-secondary text-sm">
      Get started with the free features right away. Upgrade anytime.
    </p>

  </div>

  <!-- Background glow -->
  <div class="absolute top-1/2 left-0 w-[700px] h-[700px] bg-primary/5 blur-[150px] rounded-full -translate-x-1/2 -translate-y-1/2 opacity-20 pointer-events-none"></div>
</section>
