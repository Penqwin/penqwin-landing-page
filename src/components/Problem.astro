<section id="problem" class="w-full py-16 md:py-24 bg-bg-main relative">
  <div class="max-w-5xl mx-auto px-6 relative z-10">
    <!-- Heading -->
    <div class="mb-12">
      <h2
        class="font-serif text-4xl md:text-5xl text-text-primary tracking-tight leading-[1.2]"
      >
        Why engineering teams choose Penqwin
      </h2>
    </div>

    <!-- Vertical list -->
    <div class="divide-y divide-white/5">
      <!-- Row 1 -->
      <div class="flex items-start gap-6 md:gap-10 py-8">
        <span
          class="flex-shrink-0 text-sm font-mono text-primary/80 pt-1 w-6 select-none"
          >01</span
        >
        <div class="flex-1">
          <p
            class="text-text-primary text-lg md:text-xl font-medium mb-2 leading-snug"
          >
            Documentation stays current as your code evolves
          </p>
          <p class="text-text-secondary text-base md:text-lg leading-relaxed">
            Keep documentation aligned with your codebase automatically as code
            changes.
          </p>
        </div>
      </div>

      <!-- Row 2 -->
      <div class="flex items-start gap-6 md:gap-10 py-6">
        <span
          class="flex-shrink-0 text-sm font-mono text-primary/80 pt-1 w-6 select-none"
          >02</span
        >
        <div class="flex-1">
          <p
            class="text-text-primary text-lg md:text-xl font-medium mb-2 leading-snug"
          >
            Understand any codebase
          </p>
          <p class="text-text-secondary text-base md:text-lg leading-relaxed">
            Generate structured documentation that makes complex repositories
            easier to explore.
          </p>
        </div>
      </div>

      <!-- Row 3 — resolution -->
      <div class="flex items-start gap-6 md:gap-10 py-6">
        <span
          class="flex-shrink-0 text-sm font-mono text-primary/80 pt-1 w-6 select-none"
          >03</span
        >
        <div class="flex-1">
          <p
            class="text-text-primary text-lg md:text-xl font-medium mb-2 leading-snug"
          >
            Faster onboarding and handovers.
          </p>
          <p class="text-text-secondary text-base md:text-lg leading-relaxed">
            New developers can get up to speed quickly without digging through
            code history.
          </p>
        </div>
      </div>
    </div>
  </div>

