---

<section id="problem" class="w-full py-20 md:py-32 bg-bg-main relative">
  <div class="max-w-5xl mx-auto px-6 relative z-10">
    <!-- Heading -->
    <div class="mb-16 md:mb-20">
      <h2
        class="font-serif text-4xl md:text-5xl text-text-primary tracking-tight leading-[1.2]"
      >
        Everything your team needs <span class="text-primary italic"
          >to stay in sync</span
        >
      </h2>
    </div>

    <!-- Vertical list -->
    <div class="divide-y divide-white/5">
      <!-- Row 1 -->
      <div class="flex items-start gap-6 md:gap-10 py-8">
        <span
          class="flex-shrink-0 text-sm font-mono text-primary/80 pt-1 w-6 select-none"
          >01</span
        >
        <div class="flex-1">
          <p
            class="text-text-primary text-lg md:text-xl font-medium mb-2 leading-snug"
          >
            Always up-to-date documentation.
          </p>
          <p class="text-text-secondary text-base md:text-lg leading-relaxed">
            Keep documentation aligned with your codebase automatically as code
            changes.
          </p>
        </div>
      </div>

      <!-- Row 2 -->
      <div class="flex items-start gap-6 md:gap-10 py-8">
        <span
          class="flex-shrink-0 text-sm font-mono text-primary/80 pt-1 w-6 select-none"
          >02</span
        >
        <div class="flex-1">
          <p
            class="text-text-primary text-lg md:text-xl font-medium mb-2 leading-snug"
          >
            No more tribal knowledge.
          </p>
          <p class="text-text-secondary text-base md:text-lg leading-relaxed">
            Turn pull requests, commits, and code changes into structured,
            searchable knowledge.
          </p>
        </div>
      </div>

      <!-- Row 3 — resolution -->
      <div class="flex items-start gap-6 md:gap-10 py-8">
        <span
          class="flex-shrink-0 text-sm font-mono text-primary/80 pt-1 w-6 select-none"
          >03</span
        >
        <div class="flex-1">
          <p
            class="text-text-primary text-lg md:text-xl font-medium mb-2 leading-snug"
          >
            Faster onboarding and handovers.
          </p>
          <p class="text-text-secondary text-base md:text-lg leading-relaxed">
            New developers can get up to speed quickly without digging through
            code history.
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- Background glow -->
  <!-- <div
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[300px] bg-primary/5 blur-[120px] rounded-full pointer-events-none opacity-40"
  >
  </div> -->
</section>
