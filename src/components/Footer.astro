---
import SnowflakeIcon from "../assets/svg/snowflake.astro";
import ArrowIcon from "../assets/svg/arrow.astro";
---

<footer class="w-full bg-bg-main relative pt-24 pb-12 overflow-hidden">
  <!-- Main Footer Container -->
  <div class="max-w-6xl mx-auto px-6 relative z-10">
    <div
      class="flex flex-col-reverse md:flex-row items-center justify-between gap-8 pt-12 border-t border-white/5"
    >
      <!-- Logo & Credit -->
      <div class="flex flex-col items-center md:items-start gap-4">
        <p
          class="flex items-center justify-center text-text-secondary text-xs sm:text-sm font-regular tracking-wide"
        >
          Made with &nbsp;<SnowflakeIcon
            class="w-3.5 h-3.5 inline-block"
          />&nbsp; for the engineering community.
        </p>
        <p
          class="text-[10px] text-text-secondary/40 font-regular tracking-[0.2em]"
        >
          &copy; {new Date().getFullYear()} Penqwin. All rights reserved.
        </p>
      </div>

      <!-- Links -->
      <nav class="flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
        <a
          href="/about"
          class="text-xs sm:text-sm font-medium text-text-secondary hover:text-text-primary transition-colors duration-200"
          >About</a
        >
        <div class="relative" id="footer-resources-container">
          <button
            id="footer-resources-btn"
            class="text-xs sm:text-sm font-medium text-text-secondary hover:text-text-primary transition-colors duration-200 flex items-center gap-1 cursor-pointer"
          >
            Resources
            <ArrowIcon
              id="footer-resources-icon"
              class="w-4 h-4 transition-transform"
              style="transform: rotate(270deg);"
            />
          </button>
          <div
            id="footer-resources-dropdown"
            class="absolute bottom-full mb-2 left-1/2 -translate-x-1/2 opacity-0 invisible transition-all duration-200 bg-bg-secondary border border-white/10 rounded-xl shadow-2xl p-2 min-w-[160px] flex flex-col z-50"
          >
            <a
              href="/notion-alternative"
              class="text-xs sm:text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-white/5 px-4 py-2.5 rounded-lg transition-colors text-center whitespace-nowrap"
            >
              Notion comparison
            </a>
          </div>
        </div>
        <a
          href="/privacy"
          class="text-xs sm:text-sm font-medium text-text-secondary hover:text-text-primary transition-colors duration-300"
          >Privacy</a
        >
        <a
          href="/terms"
          class="text-xs sm:text-sm font-medium text-text-secondary hover:text-text-primary transition-colors duration-300"
          >Terms</a
        >
        <span class="hidden md:block border-r border-border h-4"></span>
        <!-- <a
          href="https://x.com/penqwinai"
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs sm:text-sm font-medium text-text-secondary hover:text-text-primary transition-colors duration-300"
          aria-label="Follow Penqwin on Twitter/X">X/Twitter</a
        > -->
        <a
          href="https://www.linkedin.com/company/penqwin"
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs sm:text-sm font-medium text-text-secondary hover:text-text-primary transition-colors duration-300"
          aria-label="Follow Penqwin on LinkedIn">LinkedIn</a
        >
        <a
          href="https://www.threads.net/@penqwinai"
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs sm:text-sm font-medium text-text-secondary hover:text-text-primary transition-colors duration-300"
          aria-label="Follow Penqwin on Threads">Threads</a
        >
        <!-- <a
          href="https://reddit.com/r/penqwin"
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs sm:text-sm font-medium text-text-secondary hover:text-text-primary transition-colors duration-300"
          aria-label="Join our community on Reddit">Reddit</a
        > -->
      </nav>
    </div>
  </div>

  <!-- Background Orbs -->
  <div
    class="absolute bottom-0 right-0 w-[400px] h-[400px] bg-primary/5 blur-[120px] rounded-full translate-y-1/2 translate-x-1/2 opacity-20 pointer-events-none"
  >
  </div>
</footer>

<script>
  const btn = document.getElementById("footer-resources-btn");
  const dropdown = document.getElementById("footer-resources-dropdown");
  const icon = document.getElementById("footer-resources-icon");

  if (btn && dropdown && icon) {
    btn.addEventListener("click", (e) => {
      e.stopPropagation();
      const isOpen = dropdown.classList.contains("opacity-100");

      if (isOpen) {
        dropdown.classList.remove("opacity-100", "visible");
        dropdown.classList.add("opacity-0", "invisible");
        icon.classList.remove("rotate-180");
      } else {
        dropdown.classList.remove("opacity-0", "invisible");
        dropdown.classList.add("opacity-100", "visible");
        icon.classList.add("rotate-180");
      }
    });

    document.addEventListener("click", (e) => {
      if (
        !btn.contains(e.target as Node) &&
        !dropdown.contains(e.target as Node)
      ) {
        dropdown.classList.remove("opacity-100", "visible");
        dropdown.classList.add("opacity-0", "invisible");
        icon.classList.remove("rotate-180");
      }
    });
  }
</script>
