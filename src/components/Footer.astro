---
import SnowflakeIcon from "../assets/svg/snowflake.astro";
import XIcon from "../assets/svg/x.astro";
import LinkedInIcon from "../assets/svg/linkedin.astro";
import ExternalIcon from "../assets/svg/external.astro";
import YouTubeIcon from "../assets/svg/youtube.astro";
import GitHubIcon from "../assets/svg/github.astro";
---

<footer class="w-full bg-bg-main text-text-secondary relative pt-20 pb-12">
  <!-- Main Footer Container -->
  <div class="max-w-6xl mx-auto px-6 relative z-10">
    <!-- Top Links Grid -->
    <div
      class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-y-10 gap-x-8 pb-16"
    >
      <!-- Column 1: Product -->
      <div class="flex flex-col gap-4">
        <h3 class="text-xs font-semibold tracking-widest text-text-muted">
          Products
        </h3>
        <ul class="flex flex-col gap-3 text-sm">
          <li>
            <a
              href="/"
              class="hover:text-primary transition-colors duration-200"
              aria-label="Knowledge Base">Knowledge Base</a
            >
          </li>
          <li>
            <a
              href="/mcp"
              class="hover:text-primary transition-colors duration-200"
              aria-label="Context Router MCP">Context Router MCP</a
            >
          </li>
          <li>
            <a
              href="https://chromewebstore.google.com/detail/aoledhaebebijfljkcjcbdfjkbciekcm"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-primary transition-colors duration-200 inline-flex items-center gap-2 group"
              aria-label="Chrome Extension"
            >
              <span>Chrome Extension</span>
              <ExternalIcon class="w-3 h-3 opacity-80" aria-hidden="true" />
            </a>
          </li>
        </ul>
      </div>

      <!-- Column 2: Why Penqwin -->
      <div class="flex flex-col gap-4">
        <h3 class="text-xs font-semibold tracking-widest text-text-muted">
          Why Penqwin
        </h3>
        <ul class="flex flex-col gap-3 text-sm">
          <li>
            <a
              href="/notion-alternative"
              class="hover:text-primary transition-colors duration-200"
              aria-label="Notion for Developers">Notion comparison</a
            >
          </li>
          <li>
            <a
              href="/gitbook-alternative"
              class="hover:text-primary transition-colors duration-200"
              aria-label="GitBook comparison">GitBook comparison</a
            >
          </li>
          <li>
            <a
              href="/stainless-alternative"
              class="hover:text-primary transition-colors duration-200"
              aria-label="Stainless comparison">Stainless comparison</a
            >
          </li>
          <li>
            <a
              href="/codewiki-alternative"
              class="hover:text-primary transition-colors duration-200"
              aria-label="Codewiki for Private Repos">Codewiki comparison</a
            >
          </li>
        </ul>
      </div>

      <!-- Column 3: Resources -->
      <div class="flex flex-col gap-4">
        <h3 class="text-xs font-semibold tracking-widest text-text-muted">
          Resources
        </h3>
        <ul class="flex flex-col gap-3 text-sm">
          <li>
            <a
              href="/features"
              class="hover:text-primary transition-colors duration-200"
              aria-label="Explore Features">Explore Features</a
            >
          </li>
          <li>
            <a
              href="/docs"
              class="hover:text-primary transition-colors duration-200"
              aria-label="Documentation">Documentation</a
            >
          </li>
          <li>
            <a
              href=""
              onclick="Calendly.initPopupWidget({url: 'https://calendly.com/sarinmsari/30min'});return false;"
              class="hover:text-primary transition-colors duration-200 cursor-pointer"
              aria-label="Book a Demo"
            >
              Book a Demo
            </a>
          </li>
          <li>
            <a
              href="/faq"
              class="hover:text-primary transition-colors duration-200"
              aria-label="Frequently Asked Questions">FAQ</a
            >
          </li>
        </ul>
      </div>

      <!-- Column 4: Company -->
      <div class="flex flex-col gap-4">
        <h3 class="text-xs font-semibold tracking-widest text-text-muted">
          Company
        </h3>
        <ul class="flex flex-col gap-3 text-sm">
          <li>
            <a
              href="/about"
              class="hover:text-primary transition-colors duration-200"
              aria-label="About Penqwin">About us</a
            >
          </li>
          <li>
            <a
              href="/privacy"
              class="hover:text-primary transition-colors duration-200"
              aria-label="Privacy Policy">Privacy Policy</a
            >
          </li>
          <li>
            <a
              href="/terms"
              class="hover:text-primary transition-colors duration-200"
              aria-label="Terms of Service">Terms of Service</a
            >
          </li>
        </ul>
      </div>

      <!-- Column 5: Social -->
      <div class="flex flex-col gap-4 col-span-2 md:col-span-1">
        <h3 class="text-xs font-semibold tracking-widest text-text-muted">
          Social
        </h3>
        <div class="flex items-center gap-4 text-text-secondary">
          <a
            href="https://x.com/penqwinai"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-primary transition-colors duration-200"
            aria-label="Follow Penqwin on Twitter/X"
          >
            <XIcon class="w-5 h-5 fill-current" />
          </a>
          <a
            href="https://www.linkedin.com/company/penqwin"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-primary transition-colors duration-200"
            aria-label="Follow Penqwin on LinkedIn"
          >
            <LinkedInIcon class="w-5 h-5 fill-current" />
          </a>
          <a
            href="https://github.com/Penqwin"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-primary transition-colors duration-200"
            aria-label="Follow Penqwin on GitHub"
          >
            <GitHubIcon class="w-5 h-5 fill-current" />
          </a>
          <a
            href="https://www.youtube.com/@doopstech"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-primary transition-colors duration-200"
            aria-label="Follow Penqwin on YouTube"
          >
            <YouTubeIcon class="w-5 h-5 fill-current" />
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom Credits & Badges -->
    <div
      class="flex flex-col md:flex-row items-center justify-between gap-8 pt-10 text-xs"
    >
      <!-- Product Hunt featured badge -->
      <a
        href="https://www.producthunt.com/products/penqwin?embed=true&utm_source=badge-featured&utm_medium=badge&utm_campaign=badge-penqwin"
        target="_blank"
        rel="noopener noreferrer"
      >
        <img
          alt="Penqwin - Engineering knowledge that evolves with your codebase | Product Hunt"
          width="200"
          height="54"
          src="https://api.producthunt.com/widgets/embed-image/v1/featured.svg?post_id=1119018&theme=neutral&t=1782309540663"
          class="opacity-80 hover:opacity-100 transition-opacity duration-200"
        />
      </a>

      <!-- Credits and copyright -->
      <div
        class="flex flex-col items-center md:items-end gap-2 text-center md:text-right"
      >
        <p
          class="flex items-center justify-center text-text-secondary font-regular tracking-wide"
        >
          Made with &nbsp;<SnowflakeIcon
            class="w-3.5 h-3.5 inline-block"
            aria-hidden="true"
          />&nbsp; for the engineering community.
        </p>
        <p
          class="text-[10px] text-text-secondary/60 font-regular tracking-wider"
        >
          &copy; {new Date().getFullYear()} Penqwin. All rights reserved.
        </p>
      </div>
    </div>
  </div>
</footer>
