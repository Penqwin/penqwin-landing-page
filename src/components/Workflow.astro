---
import WorkflowCard from "./WorkflowCard.astro";
import AiGenerateIcon from "../assets/svg/aiGenerate.astro";
import AddLink from "../assets/svg/addLink.astro";
import Assistant from "../assets/svg/assistant.astro";
---

<section
  id="workflow"
  class="w-full py-16 md:py-32 bg-bg-main relative overflow-hidden"
>
  <div class="max-w-6xl mx-auto px-6 relative z-10">
    <div class="text-center mb-20">
      <h2
        class="font-serif text-4xl md:text-5xl text-text-primary tracking-tight mb-4"
      >
        Documentation <span class="text-primary italic">reimagined</span>
      </h2>
      <p class="text-text-secondary text-lg max-w-xl mx-auto">
        Documentation that's never out of date.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 relative">
      <!-- Connecting Lines (Desktop) -->
      <div
        class="hidden md:block absolute top-1/2 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-white/10 to-transparent -translate-y-1/2 z-0"
      >
      </div>

      <WorkflowCard
        step="01"
        title="Connect"
        description="Connect your GitHub repository. Penqwin analyzes your codebase and generates initial documentation."
      >
        <AddLink slot="icon" class="w-10 h-10" />
      </WorkflowCard>

      <WorkflowCard
        step="02"
        title="Monitor"
        description="Our AI agent analyzes the PRs and commits, understanding the impact of code changes."
      >
        <Assistant slot="icon" class="w-8 h-8" />
      </WorkflowCard>

      <WorkflowCard
        step="03"
        title="Evolve"
        description="Documentation that keeps up. Human supervised AI that syncs your technical guides to your codebase."
      >
        <AiGenerateIcon slot="icon" class="w-8 h-8" />
      </WorkflowCard>
    </div>
  </div>

  <!-- Background Decorative Glow -->
  <div
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[400px] bg-primary/5 blur-[120px] rounded-full z-0 opacity-50"
  >
  </div>
</section>
