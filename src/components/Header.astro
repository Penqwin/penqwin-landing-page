---
import penqwinWebp from "../assets/images/penqwin-primary.webp";
import penqwinPng from "../assets/images/penqwin-primary.png";
import ArrowRight from "../assets/svg/arrow-right.astro";
---

<header
  class="fixed top-0 left-0 right-0 z-50 flex justify-center p-6 pointer-events-none transition-all duration-500 ease-in-out"
  id="main-header"
>
  <nav
    class="w-full max-w-5xl px-6 py-3 flex items-center justify-between pointer-events-auto bg-bg-secondary/40 backdrop-blur-xl border border-white/5 rounded-2xl shadow-2xl"
  >
    <a
      href="/"
      class="flex items-center gap-2 select-none"
      aria-label="Penqwin Home"
    >
      <picture>
        <source srcset={penqwinWebp.src} type="image/webp" />
        <img src={penqwinPng.src} alt="Penqwin Logo" class="w-16 h-auto" />
      </picture>
    </a>

    <div class="hidden md:flex items-center gap-8 select-none">
      <a
        href="/features"
        class="text-sm font-medium text-text-secondary hover:text-text-primary transition-colors duration-200"
        >Features</a
      >
      <a
        href="/about  "
        class="text-sm font-medium text-text-secondary hover:text-text-primary transition-colors duration-200"
        >About</a
      >
      <a
        href="/faq"
        class="text-sm font-medium text-text-secondary hover:text-text-primary transition-colors duration-200"
        >FAQ</a
      >
    </div>

    <div class="flex items-center gap-4">
      <a
        href="https://app.penqwin.com"
        class="group select-none px-4 py-2 flex items-center gap-1 bg-text-primary text-bg-main rounded-xl text-sm font-semibold hover:bg-white transition-all duration-300 shadow-sm active:scale-95"
        aria-label="Go to Dashboard"
      >
        Dashboard
        <ArrowRight
          class="w-4 inline-block group-hover:translate-x-1"
          aria-hidden="true"
        />
      </a>
    </div>
  </nav>
</header>

<script>
  let lastScrollY = window.pageYOffset;
  const header = document.getElementById("main-header");
  const scrollThreshold = 10; // min scroll amount to trigger logic

  window.addEventListener(
    "scroll",
    () => {
      const currentScrollY = window.pageYOffset;

      // Ignore small scrolls
      if (Math.abs(currentScrollY - lastScrollY) < scrollThreshold) {
        return;
      }

      if (header) {
        if (currentScrollY > lastScrollY && currentScrollY > 100) {
          // Scrolling down - hide
          header.classList.add("header-hidden");
        } else {
          // Scrolling up - show
          header.classList.remove("header-hidden");
        }
      }

      lastScrollY = currentScrollY <= 0 ? 0 : currentScrollY; // For Mobile or negative scrolling
    },
    { passive: true },
  );
</script>

<style>
  #main-header {
    transform: translateY(0);
    will-change: transform;
  }

  .header-hidden {
    transform: translateY(-100%) !important;
  }

  /* Subtle glow effect on hover for the nav */
  nav {
    transition:
      border-color 0.3s ease,
      box-shadow 0.3s ease;
  }
  nav:hover {
    border-color: rgba(139, 92, 246, 0.2);
    box-shadow: 0 0 40px -10px rgba(139, 92, 246, 0.1);
  }
</style>
