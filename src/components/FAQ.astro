---
import Arrow from "../assets/svg/arrow.astro";

interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items: FAQItem[];
}

const { items } = Astro.props;
---

<div class="faq-container space-y-4">
  {
    items.map((item, index) => (
      <details class="group border border-border rounded-2xl overflow-hidden transition-all duration-300">
        <summary class="flex items-center justify-between p-6 cursor-pointer list-none">
          <span class="text-lg md:text-xl font-serif text-text-primary transition-colors">
            {item.question}
          </span>
          <span class="relative flex-shrink-0 ml-4 w-5 h-5 transition-transform duration-300 rotate-90 group-open:rotate-270">
            <Arrow class="w-5 h-5 text-text-secondary group-open:text-text-primary" />
          </span>
        </summary>
        <div class="px-6 pb-6 text-text-secondary leading-relaxed max-w-2xl">
          <p class="text-base">{item.answer}</p>
        </div>
      </details>
    ))
  }
</div>

<style>
  details summary::-webkit-details-marker {
    display: none;
  }

  details[open] summary ~ * {
    animation: slide-down 0.3s ease-out;
  }

  @keyframes slide-down {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
