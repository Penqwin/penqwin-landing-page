---
import DashboardPreview from "./DashboardPreview.astro";
---

<section
  id="hero"
  class="w-full min-h-screen bg-bg-main flex flex-col items-center justify-center"
>
  <div class="max-w-4xl px-6 mt-52 text-center">
    <h1
      class="font-serif text-5xl md:text-7xl text-text-primary tracking-tight leading-[1.1] mb-6"
    >
      Stop writing docs.<br />
      <em class="text-primary">Start syncing it.</em>
    </h1>

    <div class="my-10">
      <a
        href="#get-started"
        class="group relative inline-flex items-center gap-3 px-8 py-4 bg-white/[0.03] backdrop-blur-md border border-white/10 text-white rounded-full font-medium transition-all duration-500 hover:bg-white/[0.08] hover:border-primary/40 hover:shadow-[0_0_40px_-10px_rgba(139,92,246,0.3)]"
      >
        <span>Sync Now</span>
        <span
          class="text-text-secondary group-hover:text-primary transition-colors duration-300"
          >|</span
        >
        <span
          class="text-sm text-text-secondary group-hover:text-text-primary transition-colors duration-300"
          >It's free</span
        >
        <span
          class="inline-block transform group-hover:translate-x-1 transition-transform duration-300 text-lg"
          >→</span
        >
      </a>
    </div>
  </div>
  <div class="w-1/2 mt-10 mb-20">
    <DashboardPreview />
  </div>
</section>
