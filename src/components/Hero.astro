---
import DashboardPreview from "./DashboardPreview.astro";
import ArrowRight from "../assets/svg/arrow-right.astro";
import PlayIcon from "../assets/svg/play.astro";
import bootstrapVideo from "../assets/videos/bootstrap_repo.mp4";
import updateDocsVideo from "../assets/videos/update_docs.mp4";
import Cross from "../assets/svg/cross.astro";
import ArrowIcon from "../assets/svg/arrow.astro";
---

<section
  id="hero"
  class="relative z-30 w-full min-h-screen bg-bg-main flex flex-col items-center justify-center"
>
  <!-- Background Effects -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <!-- Grid Pattern -->
    <div
      class="absolute inset-0 bg-grid opacity-[0.03] [mask-image:radial-gradient(ellipse_at_center,black,transparent_80%)]"
    >
    </div>

    <!-- Ambient Glows -->
    <div
      class="absolute top-[20%] left-[10%] w-[500px] h-[500px] bg-primary/10 blur-[120px] rounded-full animate-pulse-slow"
    >
    </div>
    <div
      class="absolute bottom-[20%] right-[10%] w-[600px] h-[600px] bg-primary/5 blur-[150px] rounded-full animate-float"
    >
    </div>

    <!-- Darkened Vignette -->
    <div
      class="absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_0%,rgba(4,4,13,0.4)_100%)]"
    >
    </div>
  </div>

  <div class="relative z-20 max-w-4xl px-6 mt-32 md:mt-48 text-center">
    <!-- H1 – keyword-rich, benefit-led -->
    <h1
      class="font-serif text-4xl md:text-7xl text-text-primary tracking-tight leading-[1.5] md:leading-[1.1] mb-6"
    >
      Engineering knowledge that <em class="text-primary"
        >evolves with your codebase</em
      >
    </h1>

    <!-- Subtitle – problem/solution, secondary keywords -->
    <p
      class="text-text-secondary text-lg md:text-xl max-w-2xl mx-auto leading-relaxed mb-10"
    >
      Penqwin bootstraps your repository into structured engineering
      documentation and keeps it updated automatically as your code evolves.
    </p>

    <!-- Primary CTA -->
    <div
      class="flex flex-col-reverse sm:flex-row items-center justify-center gap-4 my-10 md:my-8"
    >
      <!-- Video Dropdown -->
      <div class="relative inline-block text-left" id="tutorial-dropdown">
        <button
          id="watch-tutorial-btn"
          class="inline-flex select-none group items-center justify-center gap-3 px-8 py-4 bg-white/5 border border-white/10 rounded-full text-white font-medium hover:bg-white/10 transition-all cursor-pointer"
          aria-label="Watch Tutorial"
          aria-haspopup="true"
          aria-expanded="false"
        >
          <span>Watch Tutorial</span>
          <ArrowIcon
            id="chevron-icon"
            class="w-5 h-5 rotate-90 transition-transform duration-200"
          />
        </button>

        <!-- Dropdown Menu -->
        <div
          id="dropdown-menu"
          class="hidden absolute left-1/2 -translate-x-1/2 mt-3 w-64 rounded-2xl bg-bg-secondary border border-border p-2 shadow-2xl z-50 transition-all duration-200 origin-top scale-95 opacity-0"
        >
          <button
            class="dropdown-item w-full flex items-center gap-3 px-4 py-3 text-left text-sm text-text-secondary hover:text-white hover:bg-white/5 rounded-xl transition-all duration-200 cursor-pointer"
            data-video-src={bootstrapVideo}
          >
            <PlayIcon
              class="w-4 h-4 group-hover:text-white transition-colors"
            />
            <div class="flex flex-col">
              <span class="font-medium text-text-primary"
                >Repository Bootstrapping</span
              >
            </div>
          </button>
          <button
            class="dropdown-item w-full flex items-center gap-3 px-4 py-3 text-left text-sm text-text-secondary hover:text-white hover:bg-white/5 rounded-xl transition-all duration-200 cursor-pointer mt-1"
            data-video-src={updateDocsVideo}
          >
            <PlayIcon
              class="w-4 h-4 group-hover:text-white transition-colors"
            />
            <div class="flex flex-col">
              <span class="font-medium text-text-primary"
                >Review & Sync Docs</span
              >
            </div>
          </button>
        </div>
      </div>

      <a
        id="hero-cta-primary"
        href="https://app.penqwin.com"
        class="group select-none relative inline-flex items-center active:scale-95 justify-center gap-3 px-8 py-4 bg-text-primary text-bg-main rounded-full font-bold transition-all duration-300 hover:bg-white hover:shadow-[0_0_40px_-10px_rgba(139,92,246,0.4)]"
        aria-label="Bootstrap Your Codebase"
      >
        <span>Bootstrap Your Codebase</span>
        <ArrowRight
          class="w-5 inline-block group-hover:translate-x-1"
          aria-hidden="true"
        />
      </a>
    </div>
  </div>
  <div
    class="hidden md:block w-full md:w-2/3 max-w-5xl mt-12 md:mt-16 mb-20 md:mb-32 px-4 md:px-6 relative z-10"
  >
    <DashboardPreview />
  </div>

  <!-- Video Dialog -->
  <dialog
    id="tutorial-modal"
    class="backdrop:bg-black/80 backdrop:backdrop-blur-sm bg-transparent border-none w-full max-w-5xl p-4 m-auto rounded-xl shadow-2xl"
  >
    <div
      class="relative w-full bg-black rounded-xl overflow-hidden border border-border-light/50"
    >
      <button
        id="close-tutorial"
        class="absolute select-none cursor-pointer top-4 right-4 z-50 p-2 bg-black/50 hover:bg-black text-text-secondary hover:text-text-primary rounded-full transition-colors"
        aria-label="Close video"
      >
        <Cross class="w-5 h-5" />
      </button>
      <video id="tutorial-video" class="w-full h-full object-contain" controls>
        <source id="tutorial-video-source" src="" type="video/mp4" />
        Your browser does not support the video tag.
      </video>
    </div>
  </dialog>
</section>

<style>
  dialog::backdrop {
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(4px);
  }

  dialog[open] {
    display: flex;
    animation: modal-fade-in 0.3s ease-out;
  }

  @keyframes modal-fade-in {
    from {
      opacity: 0;
      transform: scale(0.95) translateY(10px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }
</style>

<script>
  const watchBtn = document.getElementById("watch-tutorial-btn");
  const chevron = document.getElementById("chevron-icon");
  const menu = document.getElementById("dropdown-menu");
  const dropdownItems = document.querySelectorAll(".dropdown-item");

  const modal = document.getElementById("tutorial-modal") as HTMLDialogElement;
  const closeBtn = document.getElementById("close-tutorial");
  const video = document.getElementById("tutorial-video") as HTMLVideoElement;
  const videoSource = document.getElementById(
    "tutorial-video-source",
  ) as HTMLSourceElement;

  if (watchBtn && menu && chevron) {
    const toggleDropdown = (show?: boolean) => {
      const isVisible =
        show !== undefined ? show : menu.classList.contains("hidden");
      if (isVisible) {
        menu.classList.remove("hidden");
        // Force reflow for transitions
        void menu.offsetHeight;
        menu.classList.remove("scale-95", "opacity-0");
        menu.classList.add("scale-100", "opacity-100");
        chevron.classList.add("rotate-270");
        chevron.classList.remove("rotate-90");
        watchBtn.setAttribute("aria-expanded", "true");
      } else {
        menu.classList.add("scale-95", "opacity-0");
        menu.classList.remove("scale-100", "opacity-100");
        chevron.classList.remove("rotate-270");
        chevron.classList.add("rotate-90");
        watchBtn.setAttribute("aria-expanded", "false");

        // Wait for animation to finish
        setTimeout(() => {
          if (watchBtn.getAttribute("aria-expanded") === "false") {
            menu.classList.add("hidden");
          }
        }, 200);
      }
    };

    watchBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      toggleDropdown();
    });

    // Close on clicking anywhere outside
    document.addEventListener("click", () => {
      toggleDropdown(false);
    });

    // Close on pressing Escape
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        toggleDropdown(false);
      }
    });

    dropdownItems.forEach((item) => {
      item.addEventListener("click", (e) => {
        e.stopPropagation();
        toggleDropdown(false);

        const videoSrc = item.getAttribute("data-video-src");
        if (videoSrc && modal && video && videoSource) {
          videoSource.src = videoSrc;
          video.load();
          modal.showModal();
          video.play().catch((err) => {
            console.error("Error playing video:", err);
          });
        }
      });
    });
  }

  if (modal && closeBtn && video && videoSource) {
    const handleClose = () => {
      modal.close();
      video.pause();
      videoSource.removeAttribute("src");
      video.load();
    };

    closeBtn.addEventListener("click", handleClose);

    // Close on click outside
    modal.addEventListener("click", (e) => {
      const dialogDimensions = modal.getBoundingClientRect();
      if (
        e.clientX < dialogDimensions.left ||
        e.clientX > dialogDimensions.right ||
        e.clientY < dialogDimensions.top ||
        e.clientY > dialogDimensions.bottom
      ) {
        handleClose();
      }
    });
  }
</script>
