---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import AstGraph from "../components/AstGraph.astro";
import External from "../assets/svg/external.astro";

const claudeConfig = `{
  "mcpServers": {
    "penqwin": {
      "command": "npx",
      "args": ["-y", "@penqwin/mcp"],
      "env": {
        "PENQWIN_API_KEY": "YOUR_API_KEY",
        "PENQWIN_ORG_ID": "YOUR_ORG_ID",
        "PENQWIN_REPO": "owner/repo_name",
        "PENQWIN_API_URL": "https://app.penqwin.com"
      }
    }
  }
}`;

const cursorConfig = `PENQWIN_API_KEY="YOUR_API_KEY"
PENQWIN_ORG_ID="YOUR_ORG_ID"
PENQWIN_REPO="owner/repo_name"
PENQWIN_API_URL="https://app.penqwin.com"`;

const antigravityConfig = `{
  "mcpServers": {
    "penqwin": {
      "command": "npx",
      "args": ["-y", "@penqwin/mcp"],
      "env": {
        "PENQWIN_API_KEY": "YOUR_API_KEY",
        "PENQWIN_ORG_ID": "YOUR_ORG_ID",
        "PENQWIN_REPO": "owner/repo_name",
        "PENQWIN_API_URL": "https://app.penqwin.com"
      }
    }
  }
}`;
---

<Layout
  title="Cut AI Token Costs & Speed Up Team Dev | Penqwin"
  description="Cut AI token costs by 99% and speed up development. Penqwin Context Router MCP syncs codebase structural blueprints instantly for your entire engineering team."
  image="/og/mcp.png"
>
  <main class="relative pb-24 overflow-hidden">
    <!-- Hero Section — full viewport, vertically centred (mirrors Hero.astro) -->
    <section
      class="relative z-30 w-full min-h-screen flex flex-col items-center justify-center text-center"
    >
      <div class="relative max-w-4xl px-6 mt-32 md:mt-48">
        <h1
          class="font-serif text-4xl md:text-7xl text-text-primary tracking-tight leading-[1.5] md:leading-[1.1] mb-6"
        >
          Cut LLM Token Costs by Routing Code Context
        </h1>
        <p
          class="text-text-secondary text-lg md:text-xl max-w-2xl mx-auto leading-relaxed mb-10"
        >
          A standardized interface for AI assistants to navigate, understand,
          and interact with your repository's engineering context.
        </p>
      </div>

      <!-- AST Graph Visualization -->
      <AstGraph />

      <!-- Action Buttons -->
      <div
        class="flex flex-col sm:flex-row items-center justify-center gap-4 my-10 md:my-8 relative z-40 w-full px-6"
      >
        <a
          href="https://www.npmjs.com/package/@penqwin/mcp"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex select-none group items-center justify-center gap-3 px-8 py-4 bg-bg-secondary/50 border border-border rounded-xl text-text-primary font-medium hover:bg-white/10 transition-all cursor-pointer"
        >
          View on npm
          <External class="w-4 h-4 inline-block ml-1" aria-hidden="true" />
        </a>
        <a
          href="#setup"
          class="group select-none relative inline-flex items-center active:scale-95 justify-center gap-3 px-8 py-4 bg-text-primary text-white rounded-xl font-bold transition-all duration-300 cursor-pointer"
        >
          Setup Config
          <!-- <ArrowRight
            class="w-5 inline-block group-hover:translate-x-1"
            aria-hidden="true"
          /> -->
        </a>
      </div>
    </section>

    <!-- AST Graph + Content below the fold -->
    <div class="max-w-4xl mx-auto px-6">
      <div class="space-y-24">
        <!-- The Problem: The AI Token Tax -->
        <section class="relative border-t border-border/30 pt-16">
          <div class="grid grid-cols-1 md:grid-cols-5 gap-8 items-start">
            <div class="md:col-span-2">
              <h2
                class="text-3xl font-serif text-text-primary tracking-tight leading-tight"
              >
                The Cost of Codebase Blindness: <br />
                The Token Tax
              </h2>
            </div>
            <div
              class="md:col-span-3 space-y-4 text-text-secondary leading-relaxed text-base md:text-lg"
            >
              <p>
                AI coding agents are incredibly powerful, but they operate
                blind. When asked a simple question like
                <code
                  class="px-1.5 py-0.5 rounded bg-bg-secondary text-primary font-mono text-sm border border-border/20"
                  >"what functions call ProcessPayment?"</code
                >, agents typically traverse your repository file-by-file.
              </p>
              <p>
                They grep across files, read entire modules, and follow imports
                sequentially. This raw document exploration can easily burn <strong
                  >40,000+ tokens</strong
                > on a single simple query. Over a development session, this "token
                tax" leads to runaway API costs, slow response times, and frequent
                context limit exhaustion.
              </p>
            </div>
          </div>
        </section>

        <!-- The Solution: Precise Code Skeleton Routing -->
        <section class="relative border-t border-border/30 pt-16">
          <div class="grid grid-cols-1 md:grid-cols-5 gap-8 items-start">
            <div class="md:col-span-2">
              <h2
                class="text-3xl font-serif text-text-primary tracking-tight leading-tight"
              >
                A Structural Map for <br />
                AI Coding Agents
              </h2>
            </div>
            <div
              class="md:col-span-3 space-y-5 text-text-secondary leading-relaxed"
            >
              <p class="text-base md:text-lg">
                The Context Router MCP solves token bloat by mapping your
                repository's skeletal structure, classes, functions, imports,
                exports, and relationships. It exposes this schema directly to
                your AI agent, allowing it to navigate code boundaries
                instantly.
              </p>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-6">
                <div
                  class="p-5 bg-white/[0.02] border border-border/30 rounded-2xl"
                >
                  <h3
                    class="font-mono text-xs uppercase tracking-wider text-text-muted mb-2"
                  >
                    Structural Navigation
                  </h3>
                  <p class="text-sm">
                    Instead of guessing filenames or reading entire directories,
                    the agent queries codebase skeletons to trace definitions,
                    imports, and cross-references.
                  </p>
                </div>
                <div
                  class="p-5 bg-white/[0.02] border border-border/30 rounded-2xl"
                >
                  <h3
                    class="font-mono text-xs uppercase tracking-wider text-text-muted mb-2"
                  >
                    Context Compression
                  </h3>
                  <p class="text-sm">
                    The agent retrieves only the relevant code signatures and
                    boundaries, stripping out unnecessary implementation details
                    to keep payloads compact and fast.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- Benchmarks Section -->
        <section class="relative border-t border-border/30 pt-16">
          <div class="mb-10 text-center md:text-left">
            <h2
              class="text-3xl font-serif text-text-primary tracking-tight mb-2"
            >
              Penqwin Context Router vs. File-by-File Search
            </h2>
            <p
              class="text-text-secondary max-w-2xl text-sm md:text-base leading-relaxed"
            >
              Transitioning from blind file crawling to structural context
              routing reduces token usage by up to <strong>99%</strong>.
            </p>
          </div>

          <div
            class="overflow-x-auto border border-border/30 rounded-2xl bg-white/[0.01]"
          >
            <table class="w-full text-left border-collapse">
              <thead>
                <tr
                  class="border-b border-border/30 bg-bg-secondary/40 text-xs font-mono uppercase tracking-wider text-text-muted"
                >
                  <th class="p-4 md:p-5 font-semibold">Query Type</th>
                  <th class="p-4 md:p-5 font-semibold text-right"
                    >Penqwin Context Router</th
                  >
                  <th class="p-4 md:p-5 font-semibold text-right"
                    >File-by-File Search</th
                  >
                  <th class="p-4 md:p-5 font-semibold text-right text-primary"
                    >Savings</th
                  >
                </tr>
              </thead>
              <tbody class="divide-y divide-border/20 text-sm">
                <tr
                  class="hover:bg-bg-secondary/10 transition-colors duration-200"
                >
                  <td class="p-4 md:p-5 font-medium text-text-primary"
                    >Find function by pattern</td
                  >
                  <td
                    class="p-4 md:p-5 font-mono text-right text-text-secondary"
                    >~200 tokens</td
                  >
                  <td class="p-4 md:p-5 font-mono text-right text-text-muted"
                    >~45,000 tokens</td
                  >
                  <td
                    class="p-4 md:p-5 font-mono text-right text-primary font-bold"
                    >225x savings</td
                  >
                </tr>
                <tr
                  class="hover:bg-bg-secondary/10 transition-colors duration-200"
                >
                  <td class="p-4 md:p-5 font-medium text-text-primary"
                    >List all HTTP routes</td
                  >
                  <td
                    class="p-4 md:p-5 font-mono text-right text-text-secondary"
                    >~400 tokens</td
                  >
                  <td class="p-4 md:p-5 font-mono text-right text-text-muted"
                    >~62,000 tokens</td
                  >
                  <td
                    class="p-4 md:p-5 font-mono text-right text-primary font-bold"
                    >155x savings</td
                  >
                </tr>
                <tr
                  class="hover:bg-bg-secondary/10 transition-colors duration-200"
                >
                  <td class="p-4 md:p-5 font-medium text-text-primary"
                    >Architecture overview</td
                  >
                  <td
                    class="p-4 md:p-5 font-mono text-right text-text-secondary"
                    >~1,500 tokens</td
                  >
                  <td class="p-4 md:p-5 font-mono text-right text-text-muted"
                    >~100,000 tokens</td
                  >
                  <td
                    class="p-4 md:p-5 font-mono text-right text-primary font-bold"
                    >67x savings</td
                  >
                </tr>
                <tr class="bg-primary/[0.02] font-semibold text-text-primary">
                  <td class="p-4 md:p-5">Total Session Average</td>
                  <td class="p-4 md:p-5 font-mono text-right text-primary"
                    >~2,100 tokens</td
                  >
                  <td class="p-4 md:p-5 font-mono text-right text-text-muted"
                    >~207,000 tokens</td
                  >
                  <td
                    class="p-4 md:p-5 font-mono text-right text-primary font-extrabold text-base"
                    >Up to 99% reduction</td
                  >
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <!-- IDE Integration & Configuration -->
        <section class="relative border-t border-border/30 pt-16" id="setup">
          <div class="grid grid-cols-1 md:grid-cols-5 gap-8 items-start">
            <div class="md:col-span-2">
              <h2
                class="text-3xl font-serif text-text-primary tracking-tight leading-tight"
              >
                IDE Setup & <br />
                Configuration
              </h2>
              <p class="text-text-secondary text-sm mt-4 leading-relaxed">
                Connect the Penqwin Context Router to your favorite AI assistant
                in seconds using the standard Model Context Protocol (MCP).
                <br /><br />
                Your <code
                  class="bg-bg-secondary px-1.5 py-0.5 rounded text-text-primary font-mono text-xs"
                  >PENQWIN_ORG_ID</code
                > and <code
                  class="bg-bg-secondary px-1.5 py-0.5 rounded text-text-primary font-mono text-xs"
                  >PENQWIN_API_KEY</code
                > can be retrieved from the <a
                  href="https://app.penqwin.com/settings"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-primary hover:underline font-semibold"
                  >app.penqwin.com/settings</a
                > &rarr; <strong>integrations</strong> tab.
              </p>
            </div>
            <div class="md:col-span-3 space-y-6">
              <!-- Tab Headers -->
              <div class="flex border-b border-border/30 gap-6 text-sm">
                <button
                  class="mcp-tab-btn active pb-3 font-medium border-b-2 border-primary text-text-primary focus:outline-none cursor-pointer"
                  data-tab="claude"
                >
                  Claude Desktop
                </button>
                <button
                  class="mcp-tab-btn pb-3 font-medium border-b-2 border-transparent text-text-muted hover:text-text-primary focus:outline-none cursor-pointer"
                  data-tab="cursor"
                >
                  Cursor
                </button>
                <button
                  class="mcp-tab-btn pb-3 font-medium border-b-2 border-transparent text-text-muted hover:text-text-primary focus:outline-none cursor-pointer"
                  data-tab="antigravity"
                >
                  Antigravity / Gemini
                </button>
              </div>

              <!-- Tab Contents -->
              <div
                class="relative bg-bg-secondary/30 border border-border/30 rounded-2xl p-6"
              >
                <!-- Claude Tab -->
                <div class="mcp-tab-content block space-y-4" id="tab-claude">
                  <p class="text-sm text-text-secondary">
                    Add the server setup to your Claude Desktop configuration
                    file.
                    <br />
                    <span class="text-xs text-text-muted"
                      >Path: <code
                        class="bg-bg-secondary px-1.5 py-0.5 rounded text-text-primary font-mono select-all"
                        >%APPDATA%\Claude\claude_desktop_config.json</code
                      ></span
                    >
                  </p>
                  <div class="relative">
                    <pre
                      class="bg-black/5 text-text-primary font-mono text-xs p-4 rounded-xl overflow-x-auto border border-border/20 max-h-[300px]"><code id="code-claude">{claudeConfig}</code></pre>
                    <button
                      class="copy-btn absolute top-3 right-3 px-3 py-1.5 text-xs bg-bg-secondary hover:bg-bg-secondary/80 border border-border/30 rounded-lg text-text-secondary hover:text-text-primary transition-all cursor-pointer font-medium"
                      data-target="code-claude"
                    >
                      Copy
                    </button>
                  </div>
                </div>

                <!-- Cursor Tab -->
                <div class="mcp-tab-content hidden space-y-4" id="tab-cursor">
                  <p class="text-sm text-text-secondary">
                    Open Cursor and navigate to <strong>Settings</strong> &rarr; <strong
                      >Features</strong
                    > &rarr; <strong>MCP</strong>. Click <strong
                      >+ Add New MCP Server</strong
                    >:
                  </p>
                  <ul
                    class="text-sm text-text-secondary space-y-2 list-disc list-inside"
                  >
                    <li>
                      <strong>Name</strong>: <code
                        class="bg-bg-secondary px-1.5 py-0.5 rounded text-text-primary font-mono select-all"
                        >penqwin</code
                      >
                    </li>
                    <li>
                      <strong>Type</strong>: <code
                        class="bg-bg-secondary px-1.5 py-0.5 rounded text-text-primary font-mono"
                        >command</code
                      >
                    </li>
                    <li>
                      <strong>Command</strong>: <code
                        class="bg-bg-secondary px-1.5 py-0.5 rounded text-text-primary font-mono select-all"
                        >npx -y @penqwin/mcp</code
                      >
                    </li>
                  </ul>
                  <p class="text-sm text-text-secondary">
                    Then define these environment variables in the settings
                    interface:
                  </p>
                  <div class="relative">
                    <pre
                      class="bg-black/5 text-text-primary font-mono text-xs p-4 rounded-xl overflow-x-auto border border-border/20"><code id="code-cursor">{cursorConfig}</code></pre>
                    <button
                      class="copy-btn absolute top-3 right-3 px-3 py-1.5 text-xs bg-bg-secondary hover:bg-bg-secondary/80 border border-border/30 rounded-lg text-text-secondary hover:text-text-primary transition-all cursor-pointer font-medium"
                      data-target="code-cursor"
                    >
                      Copy
                    </button>
                  </div>
                </div>

                <!-- Antigravity Tab -->
                <div
                  class="mcp-tab-content hidden space-y-4"
                  id="tab-antigravity"
                >
                  <p class="text-sm text-text-secondary">
                    Add the server setup to your user-level Gemini config file.
                    <br />
                    <span class="text-xs text-text-muted"
                      >Path: <code
                        class="bg-bg-secondary px-1.5 py-0.5 rounded text-text-primary font-mono select-all"
                        >~/.gemini/mcp_config.json</code
                      ></span
                    >
                  </p>
                  <div class="relative">
                    <pre
                      class="bg-black/5 text-text-primary font-mono text-xs p-4 rounded-xl overflow-x-auto border border-border/20 max-h-[300px]"><code id="code-antigravity">{antigravityConfig}</code></pre>
                    <button
                      class="copy-btn absolute top-3 right-3 px-3 py-1.5 text-xs bg-bg-secondary hover:bg-bg-secondary/80 border border-border/30 rounded-lg text-text-secondary hover:text-text-primary transition-all cursor-pointer font-medium"
                      data-target="code-antigravity"
                    >
                      Copy
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- Scale, Performance & Privacy -->
        <section class="relative border-t border-border/30 pt-16">
          <div class="grid grid-cols-1 md:grid-cols-5 gap-8 items-start">
            <div class="md:col-span-2">
              <h2
                class="text-3xl font-serif text-text-primary tracking-tight leading-tight"
              >
                Designed for <br />
                Engineering Teams
              </h2>
            </div>
            <div
              class="md:col-span-3 space-y-6 text-text-secondary leading-relaxed"
            >
              <p class="text-base md:text-lg">
                The Context Router MCP is engineered for speed and footprint
                efficiency, easily scaling to compile and route structural
                blueprints for enterprise-grade repositories.
              </p>

              <div class="space-y-4">
                <div class="flex items-start gap-4">
                  <div
                    class="w-1.5 h-1.5 rounded-full bg-primary mt-2 flex-shrink-0"
                  >
                  </div>
                  <div>
                    <strong class="text-text-primary"
                      >Sub-Second Re-Indexing:</strong
                    > Average-sized repositories are parsed and indexed in milliseconds,
                    updating your agent’s memory instantly as you type.
                  </div>
                </div>
                <div class="flex items-start gap-4">
                  <div
                    class="w-1.5 h-1.5 rounded-full bg-primary mt-2 flex-shrink-0"
                  >
                  </div>
                  <div>
                    <strong class="text-text-primary"
                      >Instant Team-Wide Sync:</strong
                    > The structural mapping is kept continuously in sync with your
                    GitHub main branch, making codebase blueprints immediately available
                    to the entire team without individual re-indexing.
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>
      </div>
    </div>
  </main>
</Layout>

<script>
  // Handle tab switching
  const tabs = document.querySelectorAll(".mcp-tab-btn");
  const tabContents = document.querySelectorAll(".mcp-tab-content");

  tabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      const targetTab = tab.getAttribute("data-tab");

      tabs.forEach((t) => {
        t.classList.remove("active", "border-primary", "text-text-primary");
        t.classList.add("border-transparent", "text-text-muted");
      });
      tab.classList.add("active", "border-primary", "text-text-primary");
      tab.classList.remove("border-transparent", "text-text-muted");

      tabContents.forEach((content) => {
        if (content.id === `tab-${targetTab}`) {
          content.classList.remove("hidden");
          content.classList.add("block");
        } else {
          content.classList.remove("block");
          content.classList.add("hidden");
        }
      });
    });
  });

  // Handle copying
  const copyButtons = document.querySelectorAll(".copy-btn");
  copyButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const targetId = btn.getAttribute("data-target");
      if (targetId) {
        const codeElement = document.getElementById(targetId);
        if (codeElement) {
          navigator.clipboard
            .writeText(codeElement.textContent || "")
            .then(() => {
              const originalText = btn.textContent;
              btn.textContent = "Copied!";
              btn.classList.add("text-primary");
              setTimeout(() => {
                btn.textContent = originalText;
                btn.classList.remove("text-primary");
              }, 2000);
            });
        }
      }
    });
  });
</script>

<style>
  /* Override primary colour to --primary (green) for the MCP page */
  :root {
    --color-primary: var(--primary);
    --color-primary-light: var(--primary-light);
  }
</style>
