	description="Automate technical writing with Penqwin. Sync your engineering documentation directly to your codebase and keep your docs updated with every commit."
>
	<Header />
	<main>
		<Hero />
		<Workflow />
		<Features />
		<Pricing />
		<BetaStatus />
	</main>
	<Footer />
</Layout>
