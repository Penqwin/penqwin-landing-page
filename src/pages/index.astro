---
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Problem from "../components/Problem.astro";
import RepoBootstrap from "../components/RepoBootstrap.astro";
import AgenticSync from "../components/AgenticSync.astro";
import EngineeringContinuity from "../components/EngineeringContinuity.astro";
import Testimonials from "../components/Testimonials.astro";
import Trust from "../components/Trust.astro";
import Pricing from "../components/Pricing.astro";
import Footer from "../components/Footer.astro";
import Layout from "../layouts/Layout.astro";

import Cross from "../assets/svg/cross.astro";
import bootstrapRepoVideo from "../assets/videos/bootstrap_repo.mp4";
import updateDocsVideo from "../assets/videos/update_docs.mp4";
---

<Layout
  title="Penqwin - AI Code Wiki & Engineering Knowledge Base for GitHub Repositories"
  description="Penqwin bootstraps GitHub repositories into structured engineering documentation and keeps docs updated automatically as code evolves. Build a self-updating engineering knowledge base from pull requests and code changes."
  image="/og/og-image.png"
>
  <Header />
  <main>
    <Hero />
    <Problem />
    <RepoBootstrap videoUrl={bootstrapRepoVideo} />
    <AgenticSync videoUrl={updateDocsVideo} />
    <EngineeringContinuity />
    <Testimonials />
    <Trust />
    <Pricing />
  </main>
  <Footer />

  <!-- Video Dialog for Section Videos -->
  <dialog
    id="section-video-modal"
    class="backdrop:bg-main/80 backdrop:backdrop-blur-sm bg-transparent border-none w-full max-w-5xl p-4 m-auto rounded-xl shadow-2xl"
  >
    <div
      class="relative w-full bg-black rounded-xl overflow-hidden border border-white/10"
    >
      <button
        id="close-section-video"
        class="absolute select-none cursor-pointer top-4 right-4 z-50 p-1 hover:bg-bg-secondary/10 text-bg-secondary/50 hover:text-bg-secondary rounded-full transition-colors"
        aria-label="Close video"
      >
        <Cross class="w-5 h-5" />
      </button>
      <video
        id="section-video-player"
        class="w-full h-full object-contain"
        controls
      >
        <source id="section-video-source" src="" type="video/mp4" />
        Your browser does not support the video tag.
      </video>
    </div>
  </dialog>

  <style>
    dialog::backdrop {
      background: rgba(242, 245, 243, 0.8);
      backdrop-filter: blur(4px);
    }

    dialog[open] {
      display: flex;
      animation: modal-fade-in 0.3s ease-out;
    }

    @keyframes modal-fade-in {
      from {
        opacity: 0;
        transform: scale(0.95) translateY(10px);
      }
      to {
        opacity: 1;
        transform: scale(1) translateY(0);
      }
    }
  </style>

  <script>
    const watchBtns = document.querySelectorAll(".watch-video-btn");
    const modal = document.getElementById(
      "section-video-modal",
    ) as HTMLDialogElement;
    const closeBtn = document.getElementById("close-section-video");
    const video = document.getElementById(
      "section-video-player",
    ) as HTMLVideoElement;
    const videoSource = document.getElementById(
      "section-video-source",
    ) as HTMLSourceElement;

    if (modal && closeBtn && video && videoSource) {
      watchBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
          const videoSrc = btn.getAttribute("data-video-src");
          if (videoSrc) {
            videoSource.src = videoSrc;
            video.load();
            modal.showModal();
            video.play().catch((err) => {
              console.error("Error playing video:", err);
            });
          }
        });
      });

      const handleClose = () => {
        modal.close();
        video.pause();
        // Clear src to stop loading/playing video in background
        videoSource.removeAttribute("src");
        video.load();
      };

      closeBtn.addEventListener("click", handleClose);

      // Close on click outside
      modal.addEventListener("click", (e) => {
        const dialogDimensions = modal.getBoundingClientRect();
        if (
          e.clientX < dialogDimensions.left ||
          e.clientX > dialogDimensions.right ||
          e.clientY < dialogDimensions.top ||
          e.clientY > dialogDimensions.bottom
        ) {
          handleClose();
        }
      });
    }
  </script>
</Layout>
