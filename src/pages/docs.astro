</style>

<script>
  const initDocsVideos = () => {
    const videoConfigs = [
      {
        videoId: "bootstrap-repo-video",
        overlayId: "bootstrap-repo-video-overlay",
      },
      { videoId: "update-docs-video", overlayId: "update-docs-video-overlay" },
    ];

    videoConfigs.forEach(({ videoId, overlayId }) => {
      const video = document.getElementById(videoId) as HTMLVideoElement;
      const overlay = document.getElementById(overlayId);

      if (video && overlay) {
        const playVideo = () => {
          overlay.classList.add("opacity-0", "pointer-events-none");
          video.controls = true;
          video.play().catch((err) => {
            console.error("Error playing video:", err);
          });
        };

        overlay.addEventListener("click", playVideo);
        video.addEventListener("click", () => {
          if (video.paused) {
            playVideo();
          } else {
            overlay.classList.remove("opacity-0", "pointer-events-none");
          }
        });

        video.addEventListener("ended", () => {
          video.controls = false;
          overlay.classList.remove("opacity-0", "pointer-events-none");
        });
      }
    });
  };

  document.addEventListener("astro:page-load", initDocsVideos);
  // Also run on initial load
  initDocsVideos();
</script>
