---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
}

const {
  title = "Penqwin | PR-Driven Engineering Documentation",
  description = "Transform GitHub PRs and Commits into structured docs instantly. Penqwin combines AI-powered generation with a specialized documentation workspace for modern dev teams.",
  image = "/og/og-image.png",
  canonicalURL = new URL(Astro.url.pathname, Astro.site).href,
} = Astro.props; // The title and description is passed from each page.

const siteName = "Penqwin";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url)} />
    <meta property="og:site_name" content={siteName} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={Astro.url} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.url)} />

    <!-- Structured Data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "Penqwin",
        "operatingSystem": "Web",
        "applicationCategory": "DeveloperApplication",
        "description": "An intelligent platform that transforms code changes into engineering documentation via a purpose-built documentation editor.",
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "USD"
        },
        "featureList": [
          "AI Documentation Generation",
          "GitHub PR & Commit Integration",
          "Specialized Documentation Workspace",
          "Multiple Workspace",
          "Unlimited Documentation"
        ]
      }
    </script>

    <!-- Google Tag Manager -->
    <script>
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != "dataLayer" ? "&l=" + l : "";
        j.async = true;
        j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, "script", "dataLayer", "GTM-NH5QCBBK");
    </script>
    <!-- End Google Tag Manager -->
  </head>
  <body class="bg-bg-main scroll-smooth">
    <slot />
    <script is:inline>
      document.addEventListener(
        "click",
        (e) => {
          const target = e.target.closest("a, button");
          if (!target || !("vibrate" in navigator)) return;

          // Standardize vibration to a subtle "tick" for all interactions
          // matching the internal direction feel.
          navigator.vibrate(10);
        },
        { passive: true },
      );
    </script>
    <!-- Google Tag Manager (noscript) -->
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-NH5QCBBK"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe></noscript
    >
    <!-- End Google Tag Manager (noscript) -->
  </body>
</html>
