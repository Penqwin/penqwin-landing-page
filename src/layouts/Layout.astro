---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
}

const {
  title = "Penqwin | Engineering Documentation",
  description = "Penqwin is the most advanced documentation platform for engineering teams. Sync your documentation directly with your codebase and automate technical writing.",
  image = "/og-image.png",
  canonicalURL = Astro.url.href,
} = Astro.props;

const siteName = "Penqwin";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url)} />
    <meta property="og:site_name" content={siteName} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={Astro.url} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.url)} />

    <!-- Structured Data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "Penqwin",
        "operatingSystem": "Web",
        "applicationCategory": "DeveloperApplication",
        "description": "Engineering documentation sync platform that automates technical writing and keeps docs up to date with code changes.",
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "USD"
        }
      }
    </script>

    <!-- Google Tag Manager -->
    <script>
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != "dataLayer" ? "&l=" + l : "";
        j.async = true;
        j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, "script", "dataLayer", "GTM-NH5QCBBK");
    </script>
    <!-- End Google Tag Manager -->
  </head>
  <body class="bg-bg-main scroll-smooth">
    <slot />
    <script is:inline>
      document.addEventListener(
        "click",
        (e) => {
          const target = e.target.closest("a, button");
          if (!target || !("vibrate" in navigator)) return;

          // Heuristic: CTAs have background colors and padding or are full-width
          const classList = target.classList;
          const className =
            typeof target.className === "string" ? target.className : "";

          const isCTA =
            classList.contains("bg-text-primary") ||
            classList.contains("bg-primary") ||
            className.includes("bg-white/") ||
            (className.includes("bg-") &&
              (className.includes("px-") ||
                className.includes("py-") ||
                classList.contains("w-full")));

          if (isCTA) {
            navigator.vibrate(30);
          } else {
            navigator.vibrate(10);
          }
        },
        { passive: true },
      );
    </script>
    <!-- Google Tag Manager (noscript) -->
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-NH5QCBBK"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe></noscript
    >
    <!-- End Google Tag Manager (noscript) -->
  </body>
</html>
